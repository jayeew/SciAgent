                    "llmMessages": [
                        {
                            "role": "system",
                            "content": "<p>You are the Slide Writer role in a PPT production team.</p><p>Return valid JSON only. The JSON must match this schema:</p><pre><code>{\n  \"title\": \"string\",\n  \"fileName\": \"string\",\n  \"themePreset\": \"business-neutral\",\n  \"slideSize\": \"wide\",\n  \"includeSpeakerNotes\": true,\n  \"slides\": [\n    {\n      \"layout\": \"title|section|title-bullets|image-right|two-column\",\n      \"title\": \"string\",\n      \"subtitle\": \"string?\",\n      \"body\": \"string?\",\n      \"bullets\": [\"string\"],\n      \"speakerNotes\": \"string?\",\n      \"imageFileNames\": [\"uploaded-file-name.png\"],\n      \"leftTitle\": \"string?\",\n      \"leftBody\": \"string?\",\n      \"leftBullets\": [\"string\"],\n      \"rightTitle\": \"string?\",\n      \"rightBody\": \"string?\",\n      \"rightBullets\": [\"string\"]\n    }\n  ]\n}</code></pre><p>Default to 8 slides. Use text-first layouts. Only reference imageFileNames when the user already uploaded those files in this conversation.</p>"
                        },
                        {
                            "role": "user",
                            "content": "<p>Original request:</p><p><span class=\"variable\" data-type=\"mention\" data-id=\"question\" data-label=\"question\">{{ question }}</span></p><p>Outline:</p><p><span class=\"variable\" data-type=\"mention\" data-id=\"$flow.state.outline\" data-label=\"$flow.state.outline\">{{ $flow.state.outline }}</span></p><p>Research notes:</p><p><span class=\"variable\" data-type=\"mention\" data-id=\"$flow.state.researchNotes\" data-label=\"$flow.state.researchNotes\">{{ $flow.state.researchNotes }}</span></p>"
                        }

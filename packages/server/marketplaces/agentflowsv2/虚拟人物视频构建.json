                    "agentKnowledgeVSEmbeddings": "",
                    "agentEnableMemory": true,
                    "agentMemoryType": "allMessages",
                    "agentUserMessage": "",
                    "agentReturnResponseAs": "assistantMessage",
                    "agentUpdateState": "",
                    "agentModelConfig": {
